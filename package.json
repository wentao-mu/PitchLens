{
  "name": "pitchlens-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "vite --host 127.0.0.1 --port 4173",
    "dev:api": ".venv/bin/uvicorn server.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:full": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "setup:api": "python3 -m venv .venv && .venv/bin/pip install -r server/requirements.txt",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "node --import tsx --test tests/analytics.test.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^7.1.7"
  }
}
